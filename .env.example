# Copy this file to .env and replace every CHANGE_ME value before deployment.

# Database
POSTGRES_USER=JellyTrack
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_IP=postgres
POSTGRES_PORT=5432
POSTGRES_DB=JellyTrack
DATABASE_URL=postgresql://JellyTrack:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/JellyTrack

# Redis
REDIS_URL=redis://redis:6379

# Core app
JELLYTRACK_MODE=single
PORT=3000
APP_PORT=3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_A_RANDOM_32_BYTE_SECRET
BACKUP_DIR=/data/backups

# Primary Jellyfin server
JELLYFIN_URL=http://jellyfin:8096
JELLYFIN_API_KEY=CHANGE_ME_JELLYFIN_API_KEY
JELLYFIN_SERVER_ID=master
JELLYFIN_SERVER_NAME=Master Jellyfin

# Security
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
JELLYFIN_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET
PLUGIN_KEY_PEPPER=CHANGE_ME_RANDOM_PLUGIN_KEY_PEPPER
PLUGIN_KEY_PREVIOUS_PEPPERS=
ALLOWED_JELLYFIN_HOSTS=jellyfin
PLUGIN_EVENT_MAX_BYTES=1048576

# Local testing only
PRISMA_USE_STUB=0
